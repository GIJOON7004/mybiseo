// ── Category Comments ──
function getCategoryComment(catName: string, pct: number, lang: Lang): string {
  if (lang !== "ko") {
    if (pct >= 80) return "Well managed";
    if (pct >= 60) return "Room for improvement";
    if (pct >= 40) return "Needs attention";
    return "Requires immediate action";
  }
  if (pct >= 80) return "양호한 상태입니다.";
  if (pct >= 60) return "개선 여지가 있습니다.";
  if (pct >= 40) return "보완이 필요합니다.";
  return "우선적 개선이 필요합니다.";
}

// ── PDF Page Constants ──
const PW = 595.28; // A4 width
const PH = 841.89; // A4 height
const ML = 56;     // Left margin
const MR = 56;     // Right margin
const MT = 68;     // Top margin (content start)
const CW = PW - ML - MR; // Content width
const MAX_Y = PH - 72;   // Max Y before page break
// Units per mm for reference
const UPM_LAYOUT = 2.835;
// Font metrics for precise badge centering
const UPM = 1000;
const ASC = 1160;
const CAP_H = 733;
const ASC_H = PH - MT - 72; // ASC * scoreFontSize / UPM
const CAP_H_LAYOUT = ASC_H * 0.9; // badgeCenterY - (ASC - CAP_H / 2) * gradeFontSize / UPM
// ASC * suffixFontSize / UPM


// ── Helper Functions ──
function statusColor(s: string) {
  if (s === "pass") return C.pass;
  if (s === "warning") return C.warn;
  return C.fail;
}
function statusBg(s: string) {
  if (s === "pass") return C.passLight;
  if (s === "warning") return C.warnLight;
  return C.failLight;
}
function statusLabel(s: string, t: Record<string, string>) {
  if (s === "pass") return t.statusPass;
  if (s === "warning") return t.statusWarning;
  return t.statusFail;
}
function gradeColor(g: string) {
  if (g === "A" || g === "B") return C.pass;
  if (g === "C") return C.warn;
  return C.fail;
}
function stripMarkdown(text: string): string {
  return text
    .replace(/\*\*(.+?)\*\*/g, "$1")
    .replace(/\*(.+?)\*/g, "$1")
    .replace(/__(.+?)__/g, "$1")
    .replace(/_(.+?)_/g, "$1")
    .replace(/^#+\s*/gm, "")
    .replace(/^[-*]\s+/gm, "• ")
    .replace(/\[([^\]]+)\]\([^)]+\)/g, "$1")
    .replace(/`([^`]+)`/g, "$1")
    .trim();
}

function drawSectionTitle(doc: any, y: number, title: string, sub?: string): number {
  // Accent bar
  doc.rect(ML, y, 4, 24).fill(C.blue);
  doc.font("KrBold").fontSize(17).fillColor(C.navy).text(title, ML + 14, y + 2, { width: CW - 14 });
  let ny = y + 28;
  if (sub) {
    doc.font("KrRegular").fontSize(9.5).fillColor(C.textLight).text(sub, ML + 14, ny, { width: CW - 14 });
    ny += 18;
  }
  return ny;
}

function drawSubTitle(doc: any, y: number, title: string): number {
  doc.font("KrBold").fontSize(13).fillColor(C.navy).text(title, ML, y, { width: CW });
  return y + 22;
}

function drawParagraph(doc: any, y: number, text: string, opts?: { fontSize?: number; color?: string; indent?: number }): number {
  const fs = opts?.fontSize || 10;
  const color = opts?.color || C.text;
  const indent = opts?.indent || 0;
  doc.font("KrRegular").fontSize(fs).fillColor(color);
  const h = doc.heightOfString(stripMarkdown(text), { width: CW - indent, lineGap: 4 });
  doc.text(stripMarkdown(text), ML + indent, y, { width: CW - indent, lineGap: 4 });
  return y + h + 6;
}

function drawInfoBox(doc: any, y: number, text: string, accentColor?: string, headerCtx?: { t: Record<string, string>; url: string }): number {
  const accent = accentColor || C.blue;
  const boxW = CW;
  const cleanText = stripMarkdown(text);

  // Robust paragraph splitting:
  // 1) Split by double newline
  let paragraphs = cleanText.split(/\n\n+/).filter((p: string) => p.trim());
  // 2) If only 1 paragraph, try splitting by numbered pattern (e.g. "1) ... 2) ...")
  if (paragraphs.length <= 1) {
    const numbered = cleanText.split(/(?=\d+\)\s)/).filter((p: string) => p.trim());
    if (numbered.length > 1) paragraphs = numbered;
  }
  // 3) If still 1 paragraph, try splitting by Korean sentence endings followed by space
  if (paragraphs.length <= 1 && cleanText.length > 300) {
    const sentences = cleanText.split(/(?<=[다요음됨함임니까][\.\!\?]?)\s+/).filter((p: string) => p.trim());
    if (sentences.length > 3) {
      // Group sentences into ~300 char chunks
      const chunks: string[] = [];
      let buf = "";
      sentences.forEach((s: string) => {
        if (buf.length + s.length > 300 && buf.length > 0) {
          chunks.push(buf.trim());
          buf = s;
        } else {
          buf += (buf ? " " : "") + s;
        }
      });
      if (buf.trim()) chunks.push(buf.trim());
      if (chunks.length > 1) paragraphs = chunks;
    }
  }
  // 4) Last resort: split by sentence-ending punctuation every ~300 chars
  if (paragraphs.length <= 1 && cleanText.length > 400) {
    const chunks: string[] = [];
    let buf = "";
    cleanText.split(/(?<=[\.\!\?]\s)/).forEach((s: string) => {
      if (buf.length + s.length > 300 && buf.length > 0) {
        chunks.push(buf.trim());
        buf = s;
      } else {
        buf += s;
      }
    });
    if (buf.trim()) chunks.push(buf.trim());
    if (chunks.length > 1) paragraphs = chunks;
  }

  const allParts = paragraphs.filter((p: string) => p.trim().length > 0);
  if (allParts.length === 0) return y; // Nothing to render

  // Helper: start a new page with header, return content start Y
  const newPageY = (): number => {
    doc.addPage();
    if (headerCtx) drawPageHeader(doc, headerCtx.t, headerCtx.url);
    return MT;
  };

  // Pre-calculate content height for dynamic layout
  doc.font("KrRegular").fontSize(10);
  let totalH = 20; // padding top + bottom
  allParts.forEach((p: string, i: number) => {
    totalH += doc.heightOfString(p.trim(), { width: boxW - 32, lineGap: 5 });
    if (i < allParts.length - 1) totalH += 10; // gap between paragraphs
  });

  // If box fits on current page, draw in one shot
  if (y + totalH <= MAX_Y) {
    // bgTint
    doc.rect(ML, y, boxW, totalH).fill(C.bgAccent);
    doc.rect(ML, y, 3.5, totalH).fill(accent);
    let ty = y + 10;
    allParts.forEach((p: string, i: number) => {
      const trimmed = p.trim();
      doc.font("KrRegular").fontSize(10).fillColor(C.text)
        .text(trimmed, ML + 16, ty, { width: boxW - 32, lineGap: 5 });
      ty += doc.heightOfString(trimmed, { width: boxW - 32, lineGap: 5 });
      if (i < allParts.length - 1) ty += 10;
    });
    return y + totalH + 8;
  }

  // Multi-page: render paragraph by paragraph
  // Key fix: only break page when remaining space is truly insufficient (< 40px)
  let cy = y;
  const PAGE_CONTENT_H = MAX_Y - MT; // usable height per page
  allParts.forEach((para: string, idx: number) => {
    const trimmed = para.trim();
    if (!trimmed) return;
    doc.font("KrRegular").fontSize(10);
    const pH = doc.heightOfString(trimmed, { width: boxW - 32, lineGap: 5 });
    const blockH = pH + (idx === 0 ? 14 : 8) + (idx === allParts.length - 1 ? 10 : 4);

    // Only break page if block doesn't fit AND remaining space is less than 40px
    const pageAvail = MAX_Y - cy;
    if (blockH > pageAvail && pageAvail < 40) {
      cy = newPageY();
    } else if (blockH > pageAvail && blockH <= PAGE_CONTENT_H) {
      // Block fits on a fresh page but not here — move to new page
      cy = newPageY();
    }
    // If blockH > PAGE_CONTENT_H, just render it on current page (avoid infinite loop)

    // Draw bgTint block for this paragraph
    const actualBlockH = Math.min(blockH, MAX_Y - cy); // clamp to available space
    doc.rect(ML, cy, boxW, actualBlockH).fill(C.bgAccent);
    doc.rect(ML, cy, 3.5, actualBlockH).fill(accent);

    const textY = cy + (idx === 0 ? 10 : 4);
    doc.font("KrRegular").fontSize(10).fillColor(C.text)
      .text(trimmed, ML + 16, textY, { width: boxW - 32, lineGap: 5 });
    cy += blockH;
  });

  return cy + 8;
}

function drawProgressBar(doc: any, x: number, y: number, w: number, pct: number, color?: string): void {
  const barH = 7;
  const fillColor = color || C.blue;
  // Background stripe
  doc.rect(x, y, w, barH).fill(C.border);
  // Progress bar fill
  const fillW = Math.max(0, Math.min(w, w * (pct / 100)));
  if (fillW > 0) {
    doc.rect(x, y, fillW, barH).fill(fillColor);
  }
}

function drawHorizontalLine(doc: any, y: number, color?: string): number {
  doc.moveTo(ML, y).lineTo(PW - MR, y).lineWidth(0.5).strokeColor(color || C.border).stroke();
  return y + 8;
}

function ensureSpace(doc: any, y: number, needed: number, headerCtx?: { t: Record<string, string>; url: string }): number {
  if (y + needed > MAX_Y) {
    doc.addPage();
    if (headerCtx) drawPageHeader(doc, headerCtx.t, headerCtx.url);
    return MT;
  }
  return y;
}

function drawPageHeader(doc: any, t: Record<string, string>, url: string): void {
  doc.font("KrRegular").fontSize(7.5).fillColor(C.textMuted)
    .text(t.brand, ML, 20, { width: CW / 2, align: "left" })
    .text(url, ML + CW / 2, 20, { width: CW / 2, align: "right" });
  doc.moveTo(ML, 36).lineTo(PW - MR, 36).lineWidth(0.5).strokeColor(C.border).stroke();
}

// ── Main Export ──
// Category name constants for i18n matching
const AI_CATEGORY_KO = "AI 인용";
const AI_CATEGORY_EN = "AI Search Visibility";

export async function generateSeoReportPdf(
  audit: SeoAuditResult,
  country?: string,
  lang: Lang = "ko",
  realityDiagnosis?: RealityDiagnosis | null,
): Promise<Buffer> {  // Apply translation if needed
  const useTranslation = lang === "en" || lang === "th";
  if (useTranslation && lang === "en") {
    // Translate result to English for non-Korean reports
    const result = audit as any;
    try { await translateResultToEnglish(result); } catch (_e) { /* fallback to original */ }
  }
  const t = i18n[lang];
  const rd = realityDiagnosis ?? null;
  const auditScore = audit.score ?? audit.totalScore ?? 0;
  const pct = audit.maxScore > 0 ? Math.round((auditScore / audit.maxScore) * 100) : 0;

  const doc = new PDFDocument({
    size: "A4",
    margins: { top: MT, bottom: 72, left: ML, right: MR },
    bufferPages: true,
    info: { Title: `${t.coverTitle} - ${audit.url}`, Author: t.brand },
  });

  doc.registerFont("KrRegular", FONT_BUFFERS.krRegular);
  doc.registerFont("KrBold", FONT_BUFFERS.krBold);

  const chunks: Buffer[] = [];
  doc.on("data", (c: Buffer) => chunks.push(c));

  // Header context for ensureSpace page breaks
  const hCtx = { t, url: audit.url };

  // ═══════════════════════════════════════════════
  // PAGE: COVER
  // ═══════════════════════════════════════════════
  // COVER PAGE — 리디자인
  doc.rect(0, 0, PW, PH).fill(C.navy);

  // 상단 브랜드 라인
  doc.font("KrRegular").fontSize(9).fillColor(C.textMuted).text(t.brand, ML, 36, { width: CW });
  // 상단 장식 라인
  doc.moveTo(ML, 56).lineTo(ML + 60, 56).lineWidth(2).strokeColor(C.blue).stroke();

  // 병원명 — 커버 상단에 크게 표시
  const hospitalDisplayName = rd?.hospitalName || audit.url.replace(/^https?:\/\//, "").replace(/\/+$/, "");
  doc.font("KrBold").fontSize(22).fillColor(C.white)
    .text(hospitalDisplayName, ML, 80, { width: CW, lineGap: 4 });
  const hospitalNameH = doc.heightOfString(hospitalDisplayName, { width: CW, lineGap: 4 });

  // 진료과 표시 (있는 경우)
  const specialty = rd?.specialty || "";
  if (specialty) {
    doc.font("KrRegular").fontSize(11).fillColor(C.blueMid)
      .text(specialty, ML, 80 + hospitalNameH + 4, { width: CW });
  }

  // 중앙 콘텐츠 영역
  const coverCenterY = 200;

  // 라벨
  doc.font("KrRegular").fontSize(10).fillColor(C.blueMid)
    .text("AI VISIBILITY DIAGNOSTIC REPORT", ML, coverCenterY, { width: CW, align: "center" });

  // 메인 타이틀
  doc.font("KrBold").fontSize(30).fillColor(C.white)
    .text(t.coverTitle, ML, coverCenterY + 26, { width: CW, align: "center" });

  // 서브타이틀
  doc.font("KrRegular").fontSize(11).fillColor(C.textMuted)
    .text(t.coverSub, ML, coverCenterY + 66, { width: CW, align: "center" });

  // 구분선
  const divY = coverCenterY + 92;
  doc.moveTo(PW / 2 - 50, divY).lineTo(PW / 2 + 50, divY).lineWidth(0.5).strokeColor(C.grayMid).stroke();

  // URL
  doc.font("KrRegular").fontSize(10).fillColor(C.blueMid)
    .text(audit.url, ML, divY + 16, { width: CW, align: "center" });

  // 점수 카드 영역 — 더 넓게
  const scoreY = divY + 52;
  const cardW = 240;
  const cardH = 150;
  const cardX = PW / 2 - cardW / 2;

  // 점수 카드 배경
  doc.roundedRect(cardX, scoreY, cardW, cardH, 8).fill(C.navyLight);

  // 점수 라벨
  doc.font("KrRegular").fontSize(10).fillColor(C.textMuted)
    .text(t.coverScore, cardX, scoreY + 12, { width: cardW, align: "center" });

  // 점수 숫자
  const scoreStr = String(Math.round(pct));
  doc.font("KrBold").fontSize(48).fillColor(C.white)
    .text(scoreStr, cardX, scoreY + 28, { width: cardW, align: "center" });

  // "/ 100"
  doc.font("KrRegular").fontSize(11).fillColor(C.textMuted)
    .text("/ 100", cardX, scoreY + 84, { width: cardW, align: "center" });

  // 등급
  doc.font("KrBold").fontSize(14).fillColor(gradeColor(audit.grade))
    .text(`${t.coverGrade}: ${audit.grade}`, cardX, scoreY + 106, { width: cardW, align: "center" });

  // 요약 통계 — 3칸 카드
  const statsY = scoreY + cardH + 24;
  const statW = (CW - 20) / 3;
  const stats = [
    { label: t.coverPassed, value: audit.summary.passed, color: C.pass },
    { label: t.coverWarnings, value: audit.summary.warnings, color: C.warn },
    { label: t.coverFailed, value: audit.summary.failed, color: C.fail },
  ];
  stats.forEach((s, i) => {
    const sx = ML + i * (statW + 10);
    // 소형 카드 배경
    doc.roundedRect(sx, statsY, statW, 44, 4).fill(C.navyLight);
    doc.font("KrRegular").fontSize(8.5).fillColor(C.textMuted)
      .text(s.label, sx, statsY + 6, { width: statW, align: "center" });
    doc.font("KrBold").fontSize(18).fillColor(s.color)
      .text(`${s.value}`, sx, statsY + 20, { width: statW, align: "center" });
  });

  // 커버 하단: 핵심 발견사항 요약 (3줄)
  const coverInsightY = statsY + 68;
  if (rd?.closingStatement) {
    doc.font("KrRegular").fontSize(8.5).fillColor(C.textMuted)
      .text(stripMarkdown(rd.closingStatement).substring(0, 200) + (rd.closingStatement.length > 200 ? "..." : ""),
        ML + 20, coverInsightY, { width: CW - 40, lineGap: 3, align: "center" });
  }

  // 하단 정보 — 날짜 포맷 개선
  const bottomY = PH - 70;
  const dateStr = new Date().toLocaleDateString(lang === "ko" ? "ko-KR" : lang === "th" ? "th-TH" : "en-US", {
    year: "numeric", month: "long", day: "numeric"
  });
  doc.font("KrRegular").fontSize(9).fillColor(C.textMuted)
    .text(`${t.coverDate}: ${dateStr}`, ML, bottomY, { width: CW, align: "center", lineBreak: false, height: 14 });

  // 하단 브랜드
  doc.font("KrRegular").fontSize(8).fillColor(C.grayMid)
    .text("mybiseo.com", ML, bottomY + 18, { width: CW, align: "center", lineBreak: false, height: 14 });

  // ═══════════════════════════════════════════════
  // PAGE: EXECUTIVE SUMMARY (커버 바로 다음)
  // ═══════════════════════════════════════════════
  doc.addPage();
  drawPageHeader(doc, t, audit.url);
  let ey = MT;

  ey = drawSectionTitle(doc, ey, t.executiveSummary, t.executiveDesc);
  ey += 8;

  // Overall score summary card
  const summCardH = 80;
  doc.roundedRect(ML, ey, CW, summCardH, 4).fill(C.bg);
  doc.roundedRect(ML, ey, CW, summCardH, 4).lineWidth(0.5).strokeColor(C.border).stroke();

  // Score
  doc.font("KrBold").fontSize(36).fillColor(C.navy)
    .text(`${pct}`, ML + 20, ey + 14, { width: 80 });
  doc.font("KrRegular").fontSize(12).fillColor(C.textMuted)
    .text("/ 100", ML + 80, ey + 30, { width: 50 });

  // Status dots
  const dotY = ey + 20;
  const dotStartX = ML + 160;
  const dotSpacing = 120;
  [
    { label: `\u25cf ${t.coverPassed} ${audit.summary.passed}`, color: C.pass },
    { label: `\u25cf ${t.coverWarnings} ${audit.summary.warnings}`, color: C.warn },
    { label: `\u25cf ${t.coverFailed} ${audit.summary.failed}`, color: C.fail },
  ].forEach((s, i) => {
    doc.font("KrBold").fontSize(10).fillColor(s.color)
      .text(s.label, dotStartX + i * dotSpacing, dotY, { width: dotSpacing });
  });

  // Grade
  doc.font("KrBold").fontSize(14).fillColor(gradeColor(audit.grade))
    .text(`${t.coverGrade} ${audit.grade}`, ML + 20, ey + 54, { width: 100 });

  ey += summCardH + 10;

  // AI Visibility Index
  const aiScore = rd?.metrics?.aiReadiness ?? 0;
  ey = ensureSpace(doc, ey, 70, hCtx);
  ey = drawSubTitle(doc, ey, t.aiVisibility);
  doc.font("KrRegular").fontSize(9).fillColor(C.textMid)
    .text(t.aiPlatforms, ML, ey, { width: CW, lineGap: 2 });
  ey += 22;

  // AI progress bar
  drawProgressBar(doc, ML, ey, CW, aiScore, aiScore >= 60 ? C.pass : aiScore >= 30 ? C.warn : C.fail);
  doc.font("KrBold").fontSize(9).fillColor(C.text)
    .text(`${aiScore}%`, ML + CW + 6, ey - 2, { width: 40 });
  ey += 16;

  const aiComment = aiScore >= 60 ? t.aiGood : aiScore >= 30 ? t.aiMedium : t.aiBad;
  doc.font("KrRegular").fontSize(9).fillColor(C.textMid)
    .text(aiComment, ML, ey, { width: CW, lineGap: 2 });
  ey += 20;

  // Category Analysis Table
  ey = ensureSpace(doc, ey, 50, hCtx);
  ey = drawHorizontalLine(doc, ey);
  ey = drawSubTitle(doc, ey, t.categoryAnalysis);

  // Table header
  const catColW = [130, 55, 55, 160, 80];
  const catRowH = 30;
  doc.rect(ML, ey, CW, catRowH).fill(C.navy);
  const catHeaders = [t.category, t.score, t.achievement, "", t.assessment];
  catHeaders.forEach((label, i) => {
    let hx = ML + 8;
    for (let j = 0; j < i; j++) hx += catColW[j];
    doc.font("KrBold").fontSize(8.5).fillColor(C.white)
      .text(label, hx, ey + 9, { width: catColW[i] - 16, align: i >= 1 && i <= 2 ? "center" : "left" });
  });
  ey += catRowH;

  // Category rows
  audit.categories.forEach((cat, idx) => {
    const catPct = cat.maxScore > 0 ? Math.round((cat.score / cat.maxScore) * 100) : 0;
    const catName = CAT_NAMES_KO[cat.name] || cat.name;
    const comment = getCategoryComment(catName, catPct, lang);
    const rowH = 32;

    ey = ensureSpace(doc, ey, rowH + 2, hCtx);
    const bgColor = idx % 2 === 0 ? C.white : C.bg;
    doc.rect(ML, ey, CW, rowH).fill(bgColor);
    doc.moveTo(ML, ey + rowH).lineTo(PW - MR, ey + rowH).lineWidth(0.3).strokeColor(C.border).stroke();

    let cx = ML + 8;
    // Category name
    doc.font("KrBold").fontSize(9).fillColor(C.text)
      .text(catName, cx, ey + 10, { width: catColW[0] - 16 });
    cx += catColW[0];
    // Score
    doc.font("KrRegular").fontSize(9).fillColor(C.textMid)
      .text(`${cat.score}/${cat.maxScore}`, cx, ey + 10, { width: catColW[1] - 8, align: "center" });
    cx += catColW[1];
    // Achievement %
    const pctColor = catPct >= 70 ? C.pass : catPct >= 40 ? C.warn : C.fail;
    doc.font("KrBold").fontSize(9).fillColor(pctColor)
      .text(`${catPct}%`, cx, ey + 10, { width: catColW[2] - 8, align: "center" });
    cx += catColW[2];
    // Progress bar
    drawProgressBar(doc, cx + 4, ey + 12, catColW[3] - 16, catPct, pctColor);
    cx += catColW[3];
    // Comment
    doc.font("KrRegular").fontSize(8).fillColor(C.textMid)
      .text(comment, cx, ey + 10, { width: catColW[4] - 8 });

    ey += rowH;
  });

  // ═══════════════════════════════════════════════
  // REALITY DIAGNOSIS PAGES
  // ═══════════════════════════════════════════════
  if (rd) {
    doc.addPage();
    drawPageHeader(doc, t, audit.url);
    let y = MT;

    y = drawSectionTitle(doc, y, t.realityTitle, t.realitySub);
    y += 6;

    // Pre-calculate content height for dynamic layout
    // Headline (rd.headline)
    if (rd.headline) {
      doc.font("KrBold").fontSize(13).fillColor(C.navy)
        .text(rd.headline, ML, y, { width: CW, lineGap: 3 });
      y += doc.heightOfString(rd.headline, { width: CW, lineGap: 3 }) + 8;
    }

    // Risk score indicator removed — user feedback: meaning unclear, no max score context

    // Executive summary box
    if (rd.executiveSummary) {
      y = drawInfoBox(doc, y, rd.executiveSummary, C.blue, { t, url: audit.url });
      y += 4;
    }

    // Exposure metrics - 3 cards in a row
    const metricW = (CW - 20) / 3;
    const metricH = Math.max(100, 70); // Math.max(100, contentH) for dynamic height
    const metrics = [
      { label: t.aiLabel, value: `${rd.metrics.aiReadiness}%`, color: C.navy },
      { label: t.naverLabel, value: `${rd.metrics.naverExposureRate}%`, color: C.pass },
      { label: t.googleLabel, value: `${rd.metrics.googleExposureRate}%`, color: C.blue },
    ];

    y = ensureSpace(doc, y, metricH + 10, hCtx);
    metrics.forEach((m, i) => {
      const mx = ML + i * (metricW + 10);
      // Card bg with bgTint
      const bgTint = i === 0 ? C.greenTint : i === 1 ? C.bgAccent : C.purpleTint;
      doc.roundedRect(mx, y, metricW, metricH, 4).fill(bgTint);
      doc.roundedRect(mx, y, metricW, metricH, 4).lineWidth(0.5).strokeColor(C.border).stroke();
      // Label
      doc.font("KrRegular").fontSize(9).fillColor(C.textLight)
        .text(m.label, mx + 12, y + 12, { width: metricW - 24 });
      // Value - larger for print readability
      doc.font("KrBold").fontSize(24).fillColor(m.color)
        .text(m.value, mx + 12, y + 30, { width: metricW - 24 });
      // Progress bar fill
      const pctVal = parseInt(m.value) || 0;
      const barW = metricW - 24;
      doc.roundedRect(mx + 12, y + metricH - 14, barW, 4, 2).fill(C.grayBar);
      doc.roundedRect(mx + 12, y + metricH - 14, barW * pctVal / 100, 4, 2).fill(m.color);
    });
    y += metricH + 16;

    // Key findings
    if (rd.keyFindings && rd.keyFindings.length > 0) {
      y = ensureSpace(doc, y, 80, hCtx);
      y = drawSubTitle(doc, y, t.keyFindings);
      rd.keyFindings.forEach((finding, i) => {
        y = ensureSpace(doc, y, 30, hCtx);
        // Background stripe for alternating rows
        if (i % 2 === 0) {
          doc.rect(ML, y - 2, CW, 24).fill(C.bg);
        }
        const numW = 20;
        // Number circle
        doc.circle(ML + 10, y + 7, 10).fill(C.bgAccent);
        doc.font("KrBold").fontSize(9).fillColor(C.blue)
          .text(`${i + 1}`, ML + 3, y + 3, { width: numW, align: "center" });
        // Text
        doc.font("KrRegular").fontSize(10).fillColor(C.text);
        const fh = doc.heightOfString(stripMarkdown(finding), { width: CW - 30, lineGap: 3 });
        doc.text(stripMarkdown(finding), ML + 28, y + 1, { width: CW - 30, lineGap: 3 });
        y += Math.max(fh + 4, 20) + 4;
      });
      y += 6;
    }

    // ── Keywords Table ──
    if (rd.keywords && rd.keywords.length > 0) {
      y = ensureSpace(doc, y, 120, hCtx);
      y = drawHorizontalLine(doc, y);
      y = drawSubTitle(doc, y, t.realityKeywords);

      // Table header
      const colW = [140, 70, 90, 90, 90];
      const headerLabels = [lang === "ko" ? "키워드" : "Keyword", t.searchVolume, t.aiLabel, t.naverLabel, t.googleLabel];
      const rowH = 28;

      // Header bg
      doc.rect(ML, y, CW, rowH).fill(C.navy);
      headerLabels.forEach((label, i) => {
        let hx = ML + 8;
        for (let j = 0; j < i; j++) hx += colW[j];
        doc.font("KrBold").fontSize(8.5).fillColor(C.white)
          .text(label, hx, y + 8, { width: colW[i] - 16, align: i === 0 ? "left" : "center" });
      });
      y += rowH;

      // Data rows
      rd.keywords.forEach((kw, idx) => {
        y = ensureSpace(doc, y, rowH + 2, hCtx);
        const bgColor = idx % 2 === 0 ? C.white : C.bg;
        doc.rect(ML, y, CW, rowH).fill(bgColor);
        // Bottom border
        doc.moveTo(ML, y + rowH).lineTo(PW - MR, y + rowH).lineWidth(0.3).strokeColor(C.border).stroke();

        let cx = ML + 8;
        // Keyword
        doc.font("KrBold").fontSize(9).fillColor(C.text)
          .text(kw.keyword, cx, y + 8, { width: colW[0] - 16 });
        cx += colW[0];
        // Volume
        doc.font("KrRegular").fontSize(9).fillColor(C.textMid)
          .text(kw.monthlySearchVolume > 0 ? kw.monthlySearchVolume.toLocaleString() : "-", cx, y + 8, { width: colW[1] - 16, align: "center" });
        cx += colW[1];
        // AI (퍼스트)
        const aiMap: Record<string, string> = { high: t.realityAiHigh, medium: t.realityAiMedium, low: t.realityAiLow };
        const aiColor = kw.ai.likelihood === "high" ? C.pass : kw.ai.likelihood === "medium" ? C.warn : C.fail;
        doc.font("KrBold").fontSize(8.5).fillColor(aiColor)
          .text(aiMap[kw.ai.likelihood] || t.realityAiNone, cx, y + 8, { width: colW[2] - 16, align: "center" });
        cx += colW[2];
        // Naver
        const naverColor = kw.naver.found ? C.pass : C.fail;
        const naverText = kw.naver.found ? t.realityExposed : t.realityNotExposed;
        doc.font("KrBold").fontSize(8.5).fillColor(naverColor)
          .text(naverText, cx, y + 8, { width: colW[3] - 16, align: "center" });
        cx += colW[3];
        // Google
        const googleColor = kw.google.found ? C.pass : C.fail;
        const googleText = kw.google.found ? t.realityExposed : t.realityNotExposed;
        doc.font("KrBold").fontSize(8.5).fillColor(googleColor)
          .text(googleText, cx, y + 8, { width: colW[4] - 16, align: "center" });

        y += rowH;
      });
      y += 8;
    }

    // ── Competitors ──
    if (rd.competitors && rd.competitors.length > 0) {
      y = ensureSpace(doc, y, 80, hCtx);
      y = drawHorizontalLine(doc, y);
      y = drawSubTitle(doc, y, t.realityCompetitors);

      // Competitor table
      const compColW = [140, 200, 140];
      const compRowH = 32;
      // Header
      doc.rect(ML, y, CW, compRowH).fill(C.navy);
      const compHeaders = [lang === "ko" ? "경쟁사" : "Competitor", lang === "ko" ? "주요 강점" : "Key Strength", lang === "ko" ? "노출 수준" : "Visibility"];
      compHeaders.forEach((label, i) => {
        let hx = ML + 8;
        for (let j = 0; j < i; j++) hx += compColW[j];
        doc.font("KrBold").fontSize(8.5).fillColor(C.white)
          .text(label, hx, y + 10, { width: compColW[i] - 16, align: i === 0 ? "left" : "left" });
      });
      y += compRowH;

      rd.competitors.forEach((comp, idx) => {
        const compText = stripMarkdown(comp.advantage || "");
        const compH = Math.max(compRowH, doc.font("KrRegular").fontSize(9).heightOfString(compText, { width: compColW[1] - 16 }) + 16);
        y = ensureSpace(doc, y, compH + 2, hCtx);
        const bgColor = idx % 2 === 0 ? C.white : C.bg;
        doc.rect(ML, y, CW, compH).fill(bgColor);
        doc.moveTo(ML, y + compH).lineTo(PW - MR, y + compH).lineWidth(0.3).strokeColor(C.border).stroke();

        let cx = ML + 8;
        doc.font("KrBold").fontSize(9).fillColor(C.text)
          .text(comp.name, cx, y + 8, { width: compColW[0] - 16 });
        cx += compColW[0];
        doc.font("KrRegular").fontSize(9).fillColor(C.textMid)
          .text(compText, cx, y + 8, { width: compColW[1] - 16, lineGap: 2 });
        cx += compColW[1];
        doc.font("KrRegular").fontSize(9).fillColor(C.textMid)
          .text(stripMarkdown(comp.estimatedVisibility || ""), cx, y + 8, { width: compColW[2] - 16 });
        y += compH;
      });
      y += 8;
    }

    // ── Content Gaps (콘텐츠 사각지대 분석) ──
    if (rd.contentGaps && rd.contentGaps.length > 0) {
      y = ensureSpace(doc, y, 120, hCtx);
      y = drawHorizontalLine(doc, y);
      y = drawSubTitle(doc, y, t.contentGapsTitle);

      // Description
      doc.font("KrRegular").fontSize(9).fillColor(C.textMid)
        .text(t.contentGapsSub, ML, y, { width: CW, lineGap: 2 });
      y += doc.heightOfString(t.contentGapsSub, { width: CW, lineGap: 2 }) + 10;

      // Content gap cards
      rd.contentGaps.forEach((gap, idx) => {
        const keywordText = stripMarkdown(gap.keyword || "");
        const intentText = stripMarkdown(gap.searchIntent || "");
        const suggestionText = stripMarkdown(gap.suggestedContent || "");
        const rationaleText = stripMarkdown((gap as any).rationale || "");

        doc.font("KrRegular").fontSize(9);
        const intentH = doc.heightOfString(intentText, { width: CW - 100, lineGap: 2 });
        const suggestionH = doc.heightOfString(suggestionText, { width: CW - 100, lineGap: 2 });
        const rationaleH = rationaleText ? doc.heightOfString(rationaleText, { width: CW - 100, lineGap: 2 }) : 0;
        const cardH = Math.max(80, 20 + intentH + suggestionH + (rationaleText ? rationaleH + 8 : 0) + 40);

        y = ensureSpace(doc, y, cardH + 8, hCtx);

        // Card background
        doc.roundedRect(ML, y, CW, cardH, 4).fill(C.bg);
        doc.roundedRect(ML, y, CW, cardH, 4).lineWidth(0.5).strokeColor(C.border).stroke();

        // Opportunity score badge (left side)
        const scoreColor = gap.opportunityScore >= 8 ? C.pass : gap.opportunityScore >= 5 ? C.warn : C.textMid;
        doc.roundedRect(ML + 10, y + 10, 50, 50, 4).fill(scoreColor);
        doc.font("KrBold").fontSize(22).fillColor(C.white)
          .text(String(gap.opportunityScore || 0), ML + 10, y + 16, { width: 50, align: "center" });
        doc.font("KrRegular").fontSize(6.5).fillColor(C.white)
          .text(t.contentGapsOpportunity, ML + 10, y + 42, { width: 50, align: "center" });

        // Keyword + difficulty badge
        const contentX = ML + 72;
        doc.font("KrBold").fontSize(10.5).fillColor(C.navy)
          .text(`#${idx + 1}  ${keywordText}`, contentX, y + 10, { width: CW - 82 });

        // Difficulty badge
        const diffMap: Record<string, string> = { "쉬움": t.contentGapsEasy, "보통": t.contentGapsNormal, "어려움": t.contentGapsHard, "Easy": t.contentGapsEasy, "Medium": t.contentGapsNormal, "Hard": t.contentGapsHard };
        const diffColor = gap.difficulty === "쉬움" || gap.difficulty === "Easy" ? C.pass : gap.difficulty === "보통" || gap.difficulty === "Medium" ? C.warn : C.fail;
        const diffLabel = diffMap[gap.difficulty] || gap.difficulty;
        const diffBadgeW = 36;
        const diffBadgeX = ML + CW - diffBadgeW - 10;
        doc.roundedRect(diffBadgeX, y + 10, diffBadgeW, 14, 3).fill(diffColor);
        doc.font("KrBold").fontSize(7).fillColor(C.white)
          .text(diffLabel, diffBadgeX, y + 13, { width: diffBadgeW, align: "center" });

        // Search intent
        let cy = y + 28;
        doc.font("KrRegular").fontSize(8.5).fillColor(C.textMid)
          .text(`${t.contentGapsIntent}: ${intentText}`, contentX, cy, { width: CW - 100, lineGap: 2 });
        cy += intentH + 6;

        // Suggested content
        doc.font("KrRegular").fontSize(8.5).fillColor(C.textLight)
          .text(`→ ${suggestionText}`, contentX, cy, { width: CW - 100, lineGap: 2 });
        cy += suggestionH + 6;

        // Rationale (근거)
        if (rationaleText) {
          doc.font("KrRegular").fontSize(8).fillColor(C.purple)
            .text(`📌 ${t.contentGapsRationale}: ${rationaleText}`, contentX, cy, { width: CW - 100, lineGap: 2 });
        }

        y += cardH + 6;
      });
      y += 8;
    }

    // ── Action Items ──
    if (rd.actionItems && rd.actionItems.length > 0) {
      y = ensureSpace(doc, y, 80, hCtx);
      y = drawHorizontalLine(doc, y);
      y = drawSubTitle(doc, y, t.realityActions);

      rd.actionItems.forEach((item, idx) => {
        y = ensureSpace(doc, y, 50, hCtx);
        // Priority badge
        const prioColor = item.priority === "high" || item.priority === "높음" ? C.fail :
          item.priority === "medium" || item.priority === "보통" ? C.warn : C.pass;
        const prioLabel = item.priority === "high" ? t.high : item.priority === "medium" ? t.medium :
          item.priority === "low" ? t.low : item.priority;

        // Card
        const actionText = stripMarkdown(item.action);
        const impactText = stripMarkdown(item.expectedImpact);
        doc.font("KrRegular").fontSize(9.5);
        const actionH = doc.heightOfString(actionText, { width: CW - 80, lineGap: 3 });
        const impactH = doc.heightOfString(impactText, { width: CW - 80, lineGap: 3 });
        const cardH = actionH + impactH + 30;

        doc.roundedRect(ML, y, CW, cardH, 3).fill(C.bg);
        doc.roundedRect(ML, y, CW, cardH, 3).lineWidth(0.5).strokeColor(C.border).stroke();

        // Priority badge
        const badgeW = 40;
        doc.roundedRect(ML + 10, y + 8, badgeW, 16, 3).fill(prioColor);
        doc.font("KrBold").fontSize(7.5).fillColor(C.white)
          .text(prioLabel, ML + 10, y + 11, { width: badgeW, align: "center" });

        // Number
        doc.font("KrBold").fontSize(9).fillColor(C.textMid)
          .text(`#${idx + 1}`, ML + 56, y + 10, { width: 30 });

        // Action text
        doc.font("KrRegular").fontSize(9.5).fillColor(C.text)
          .text(actionText, ML + 14, y + 30, { width: CW - 28, lineGap: 3 });

        // Impact
        doc.font("KrRegular").fontSize(8.5).fillColor(C.textLight)
          .text(`→ ${impactText}`, ML + 14, y + 30 + actionH + 4, { width: CW - 28, lineGap: 3 });

        y += cardH + 8;
      });
      y += 6;
    }

    // ── Closing Statement (종합 의견) ──
    if (rd.closingStatement) {
      y = ensureSpace(doc, y, 60, hCtx);
      y = drawHorizontalLine(doc, y);
      y = drawSubTitle(doc, y, t.realityConclusion);
      y = drawInfoBox(doc, y, rd.closingStatement, C.navy, { t, url: audit.url });
    }

    // ═══════════════════════════════════════════════
    // SECTION: GEO 3축 진단 (R×A/F)
    // ═══════════════════════════════════════════════
    if (rd.geoTriAxis) {
      doc.addPage();
      drawPageHeader(doc, t, audit.url);
      let gy = MT;
      gy = drawSectionTitle(doc, gy, t.geoTriAxisTitle, t.geoTriAxisSub);
      // Why 문구
      if (t.geoTriAxisWhy) {
        doc.font("KrRegular").fontSize(8.5).fillColor(C.blue)
          .text(t.geoTriAxisWhy, ML, gy + 4, { width: CW, lineGap: 2 });
        gy += doc.heightOfString(t.geoTriAxisWhy, { width: CW, lineGap: 2 }) + 12;
      } else {
        gy += 8;
      }

      // 3축 바 차트 (Horizontal bar chart)
      const axes = [
        { label: t.geoRelevance, data: rd.geoTriAxis.relevance, color: C.blue },
        { label: t.geoAuthority, data: rd.geoTriAxis.authority, color: C.purple },
        { label: t.geoFriction, data: rd.geoTriAxis.friction, color: C.fail },
      ];
      const barH = 28;
      const barGap = 50;
      axes.forEach((axis) => {
        gy = ensureSpace(doc, gy, barH + barGap, hCtx);
        // Label
        doc.font("KrBold").fontSize(10).fillColor(C.text)
          .text(axis.label, ML, gy, { width: 160 });
        doc.font("KrRegular").fontSize(9).fillColor(C.textMid)
          .text(axis.data.label || "", ML + 165, gy + 2, { width: 80 });
        // Score
        doc.font("KrBold").fontSize(14).fillColor(axis.color)
          .text(`${axis.data.score}`, ML + CW - 50, gy - 2, { width: 50, align: "right" });
        gy += 18;
        // Bar background
        const barW = CW - 60;
        doc.roundedRect(ML, gy, barW, barH, 4).fill(C.bgWarm);
        // Bar fill
        const fillW = Math.max(4, barW * axis.data.score / 100);
        doc.roundedRect(ML, gy, fillW, barH, 4).fill(axis.color);
        // Score inside bar
        doc.font("KrBold").fontSize(11).fillColor(C.white)
          .text(`${axis.data.score}/100`, ML + 10, gy + 7, { width: fillW - 20 });
        gy += barH + 6;
        // Details
        if (axis.data.details && axis.data.details.length > 0) {
          axis.data.details.forEach((d: string) => {
            gy = ensureSpace(doc, gy, 16, hCtx);
            doc.font("KrRegular").fontSize(8.5).fillColor(C.textMid)
              .text(`  • ${stripMarkdown(d)}`, ML + 8, gy, { width: CW - 20, lineGap: 2 });
            gy += doc.heightOfString(`  • ${stripMarkdown(d)}`, { width: CW - 20, lineGap: 2 }) + 2;
          });
        }
        gy += 8;
      });

      // GEO 종합 점수 — 동적 높이 계산으로 overflow 방지
      const interpText = rd.geoTriAxis.interpretation ? stripMarkdown(rd.geoTriAxis.interpretation) : "";
      doc.font("KrRegular").fontSize(9);
      const interpH = interpText ? doc.heightOfString(interpText, { width: CW - 230, lineGap: 3 }) : 0;
      const geoScoreBoxH = Math.max(70, interpH + 28);
      gy = ensureSpace(doc, gy, geoScoreBoxH + 16, hCtx);
      doc.roundedRect(ML, gy, CW, geoScoreBoxH, 6).fill(C.navy);
      doc.font("KrRegular").fontSize(10).fillColor(C.textMuted)
        .text(t.geoOverall, ML + 20, gy + 12, { width: 200 });
      doc.font("KrBold").fontSize(32).fillColor(C.white)
        .text(`${rd.geoTriAxis.overallGeoScore}`, ML + 20, gy + 26, { width: 100 });
      doc.font("KrRegular").fontSize(10).fillColor(C.blueMid)
        .text("/ 100", ML + 85, gy + 38, { width: 50 });
      // Interpretation — 동적 높이 적용
      if (interpText) {
        doc.font("KrRegular").fontSize(9).fillColor(C.blueTintLight)
          .text(interpText, ML + 210, gy + 14, { width: CW - 230, lineGap: 3 });
      }
      gy += geoScoreBoxH + 16;
    }

    // ═══════════════════════════════════════════════
    // SECTION: AI 인용 임계점 체크리스트
    // ═══════════════════════════════════════════════
    if (rd.aiCitationThreshold && rd.aiCitationThreshold.items.length > 0) {
      doc.addPage();
      drawPageHeader(doc, t, audit.url);
      let cy = MT;
      cy = drawSectionTitle(doc, cy, t.aiCitationTitle, t.aiCitationSub);
      if (t.aiCitationWhy) {
        doc.font("KrRegular").fontSize(8.5).fillColor(C.blue)
          .text(t.aiCitationWhy, ML, cy + 4, { width: CW, lineGap: 2 });
        cy += doc.heightOfString(t.aiCitationWhy, { width: CW, lineGap: 2 }) + 12;
      } else {
        cy += 8;
      }

      // Summary bar
      const metPct = rd.aiCitationThreshold.totalCount > 0
        ? Math.round((rd.aiCitationThreshold.metCount / rd.aiCitationThreshold.totalCount) * 100) : 0;
      const summaryH = 40;
      doc.roundedRect(ML, cy, CW, summaryH, 4).fill(metPct >= 80 ? C.passLight : metPct >= 40 ? C.warnLight : C.failLight);
      doc.font("KrBold").fontSize(14).fillColor(metPct >= 80 ? C.pass : metPct >= 40 ? C.warn : C.fail)
        .text(`${rd.aiCitationThreshold.metCount} / ${rd.aiCitationThreshold.totalCount} ${t.aiCitationMet}`, ML + 16, cy + 10, { width: 200 });
      // Progress bar
      const progW = CW - 250;
      doc.roundedRect(ML + 230, cy + 14, progW, 12, 3).fill(C.grayBar);
      doc.roundedRect(ML + 230, cy + 14, progW * metPct / 100, 12, 3).fill(metPct >= 80 ? C.pass : metPct >= 40 ? C.warn : C.fail);
      cy += summaryH + 12;

      // Checklist items
      rd.aiCitationThreshold.items.forEach((item, idx) => {
        // 동적 높이 계산으로 텍스트 깨짐 방지
        const detailStr = stripMarkdown(item.detail);
        const condStr = stripMarkdown(item.condition);
        const fixStr = (!item.met && item.howToFix) ? stripMarkdown(item.howToFix) : "";
        doc.font("KrRegular").fontSize(8.5);
        const detailH = detailStr ? doc.heightOfString(detailStr, { width: CW - 56, lineGap: 2 }) : 0;
        doc.font("KrRegular").fontSize(8);
        const fixH = fixStr ? doc.heightOfString(`\u2192 ${fixStr}`, { width: CW - 56, lineGap: 2 }) : 0;
        const itemH = Math.max(50, 28 + detailH + fixH + 8);

        cy = ensureSpace(doc, cy, itemH + 8, hCtx);
        const bgCol = item.met ? C.greenTint : C.redTint;
        doc.roundedRect(ML, cy, CW, itemH, 3).fill(bgCol);
        doc.roundedRect(ML, cy, CW, itemH, 3).lineWidth(0.5).strokeColor(item.met ? C.pass : C.fail).stroke();
        // Check/X icon
        const icon = item.met ? "\u2713" : "\u2717";
        doc.font("KrBold").fontSize(16).fillColor(item.met ? C.pass : C.fail)
          .text(icon, ML + 12, cy + 8, { width: 24 });
        // Condition
        doc.font("KrBold").fontSize(10).fillColor(C.text)
          .text(condStr, ML + 40, cy + 8, { width: CW - 130 });
        // Status badge
        const badgeLabel = item.met ? t.aiCitationMet : t.aiCitationNotMet;
        const badgeColor = item.met ? C.pass : C.fail;
        doc.roundedRect(ML + CW - 72, cy + 8, 58, 18, 3).fill(badgeColor);
        doc.font("KrBold").fontSize(7.5).fillColor(C.white)
          .text(badgeLabel, ML + CW - 72, cy + 12, { width: 58, align: "center" });
        // Detail
        let iy = cy + 28;
        if (detailStr) {
          doc.font("KrRegular").fontSize(8.5).fillColor(C.textMid)
            .text(detailStr, ML + 40, iy, { width: CW - 56, lineGap: 2 });
          iy += detailH + 4;
        }
        // How to fix (if not met)
        if (fixStr) {
          doc.font("KrRegular").fontSize(8).fillColor(C.fail)
            .text(`\u2192 ${fixStr}`, ML + 40, iy, { width: CW - 56, lineGap: 2 });
        }
        cy += itemH + 8;
      });

      // Verdict
      if (rd.aiCitationThreshold.verdict) {
        cy = ensureSpace(doc, cy, 40, hCtx);
        cy += 4;
        cy = drawInfoBox(doc, cy, rd.aiCitationThreshold.verdict, metPct >= 80 ? C.pass : metPct >= 40 ? C.warn : C.fail, hCtx);
      }
    }

    // ═══════════════════════════════════════════════
    // SECTION: 답변 캡슐 품질 진단
    // ═══════════════════════════════════════════════
    if (rd.answerCapsule) {
      doc.addPage();
      drawPageHeader(doc, t, audit.url);
      let ay = MT;
      ay = drawSectionTitle(doc, ay, t.answerCapsuleTitle, t.answerCapsuleSub);
      if (t.answerCapsuleWhy) {
        doc.font("KrRegular").fontSize(8.5).fillColor(C.blue)
          .text(t.answerCapsuleWhy, ML, ay + 4, { width: CW, lineGap: 2 });
        ay += doc.heightOfString(t.answerCapsuleWhy, { width: CW, lineGap: 2 }) + 12;
      } else {
        ay += 8;
      }

      // Score card
      const capsuleScoreH = 50;
      const capsuleColor = rd.answerCapsule.score >= 70 ? C.pass : rd.answerCapsule.score >= 40 ? C.warn : C.fail;
      doc.roundedRect(ML, ay, CW, capsuleScoreH, 4).fill(C.bg);
      doc.roundedRect(ML, ay, CW, capsuleScoreH, 4).lineWidth(0.5).strokeColor(C.border).stroke();
      doc.font("KrRegular").fontSize(9).fillColor(C.textLight)
        .text(t.answerCapsuleScore, ML + 16, ay + 8, { width: 120 });
      doc.font("KrBold").fontSize(28).fillColor(capsuleColor)
        .text(`${rd.answerCapsule.score}`, ML + 16, ay + 20, { width: 60 });
      doc.font("KrRegular").fontSize(9).fillColor(C.textMuted)
        .text("/ 100", ML + 60, ay + 30, { width: 40 });
      // Progress bar
      const capBarW = CW - 200;
      doc.roundedRect(ML + 180, ay + 22, capBarW, 10, 3).fill(C.grayBar);
      doc.roundedRect(ML + 180, ay + 22, capBarW * rd.answerCapsule.score / 100, 10, 3).fill(capsuleColor);
      ay += capsuleScoreH + 12;

      // Current best sentence
      if (rd.answerCapsule.currentBestSentence) {
        ay = ensureSpace(doc, ay, 50, hCtx);
        ay = drawSubTitle(doc, ay, t.answerCapsuleCurrent);
        ay = drawInfoBox(doc, ay, rd.answerCapsule.currentBestSentence, C.textMid, hCtx);
        ay += 4;
      }

      // Issues
      if (rd.answerCapsule.issues && rd.answerCapsule.issues.length > 0) {
        ay = ensureSpace(doc, ay, 40, hCtx);
        ay = drawSubTitle(doc, ay, t.answerCapsuleIssues);
        rd.answerCapsule.issues.forEach((issue) => {
          ay = ensureSpace(doc, ay, 18, hCtx);
          doc.font("KrRegular").fontSize(9).fillColor(C.fail)
            .text(`• ${stripMarkdown(issue)}`, ML + 8, ay, { width: CW - 16, lineGap: 2 });
          ay += doc.heightOfString(`• ${stripMarkdown(issue)}`, { width: CW - 16, lineGap: 2 }) + 3;
        });
        ay += 4;
      }

      // Ideal sentence (sample rewrite)
      if (rd.answerCapsule.idealSentence) {
        ay = ensureSpace(doc, ay, 50, hCtx);
        ay = drawSubTitle(doc, ay, t.answerCapsuleSample);
        ay = drawInfoBox(doc, ay, rd.answerCapsule.idealSentence, C.pass, hCtx);
      }

      // Recommendations
      if (rd.answerCapsule.recommendations && rd.answerCapsule.recommendations.length > 0) {
        ay += 8;
        rd.answerCapsule.recommendations.forEach((rec) => {
          ay = ensureSpace(doc, ay, 18, hCtx);
          doc.font("KrRegular").fontSize(9).fillColor(C.pass)
            .text(`→ ${stripMarkdown(rec)}`, ML + 8, ay, { width: CW - 16, lineGap: 2 });
          ay += doc.heightOfString(`→ ${stripMarkdown(rec)}`, { width: CW - 16, lineGap: 2 }) + 3;
        });
      }
    }

    // ═══════════════════════════════════════════════
    // SECTION: 4채널 교차 신뢰 진단
    // ═══════════════════════════════════════════════
    if (rd.crossChannelTrust && rd.crossChannelTrust.channels.length > 0) {
      doc.addPage();
      drawPageHeader(doc, t, audit.url);
      let ccy = MT;
      ccy = drawSectionTitle(doc, ccy, t.crossChannelTitle, t.crossChannelSub);
      if (t.crossChannelWhy) {
        doc.font("KrRegular").fontSize(8.5).fillColor(C.blue)
          .text(t.crossChannelWhy, ML, ccy + 4, { width: CW, lineGap: 2 });
        ccy += doc.heightOfString(t.crossChannelWhy, { width: CW, lineGap: 2 }) + 12;
      } else {
        ccy += 8;
      }

      // Overall score
      const ccScoreH = 40;
      const ccColor = rd.crossChannelTrust.overallConsistency >= 70 ? C.pass : rd.crossChannelTrust.overallConsistency >= 40 ? C.warn : C.fail;
      doc.roundedRect(ML, ccy, CW, ccScoreH, 4).fill(C.navy);
      doc.font("KrRegular").fontSize(9).fillColor(C.textMuted)
        .text(t.crossChannelOverall, ML + 16, ccy + 6, { width: 200 });
      doc.font("KrBold").fontSize(22).fillColor(C.white)
        .text(`${rd.crossChannelTrust.overallConsistency}`, ML + 16, ccy + 16, { width: 60 });
      doc.font("KrRegular").fontSize(9).fillColor(C.blueMid)
        .text("/ 100", ML + 60, ccy + 22, { width: 40 });
      ccy += ccScoreH + 12;

      // Channel cards (2x2 grid)
      const chCardW = (CW - 12) / 2;
      const chCardH = 80;
      rd.crossChannelTrust.channels.forEach((ch, idx) => {
        const col = idx % 2;
        const row = Math.floor(idx / 2);
        if (col === 0 && row > 0) ccy += chCardH + 8;
        if (col === 0) ccy = ensureSpace(doc, ccy, chCardH + 8, hCtx);
        const cx = ML + col * (chCardW + 12);
        const cy = col === 0 ? ccy : ccy;

        const chColor = ch.status === "활성" ? C.pass : ch.status === "미흡" ? C.warn : C.fail;
        const chBg = ch.status === "활성" ? C.greenTint : ch.status === "미흡" ? C.warnLight : C.failLight;
        doc.roundedRect(cx, cy, chCardW, chCardH, 4).fill(chBg);
        doc.roundedRect(cx, cy, chCardW, chCardH, 4).lineWidth(0.5).strokeColor(chColor).stroke();
        // Channel name
        doc.font("KrBold").fontSize(10).fillColor(C.text)
          .text(ch.name, cx + 12, cy + 8, { width: chCardW - 80 });
        // Status badge
        doc.roundedRect(cx + chCardW - 60, cy + 6, 48, 16, 3).fill(chColor);
        doc.font("KrBold").fontSize(7.5).fillColor(C.white)
          .text(ch.status, cx + chCardW - 60, cy + 9, { width: 48, align: "center" });
        // Score
        doc.font("KrBold").fontSize(18).fillColor(chColor)
          .text(`${ch.consistencyScore}`, cx + 12, cy + 28, { width: 50 });
        // Detail
        doc.font("KrRegular").fontSize(8).fillColor(C.textMid)
          .text(stripMarkdown(ch.detail), cx + 12, cy + 52, { width: chCardW - 24, lineGap: 2 });
      });
      ccy += chCardH + 12;

      // Verdict
      if (rd.crossChannelTrust.verdict) {
        ccy = ensureSpace(doc, ccy, 40, hCtx);
        ccy = drawInfoBox(doc, ccy, rd.crossChannelTrust.verdict, ccColor, hCtx);
      }
    }

    // ═══════════════════════════════════════════════
    // SECTION: AI 추천 시뮬레이터
    // ═══════════════════════════════════════════════
    if (rd.aiSimulator && rd.aiSimulator.results.length > 0) {
      doc.addPage();
      drawPageHeader(doc, t, audit.url);
      let sy = MT;
      sy = drawSectionTitle(doc, sy, t.aiSimulatorTitle, t.aiSimulatorSub);
      if (t.aiSimulatorWhy) {
        doc.font("KrRegular").fontSize(8.5).fillColor(C.blue)
          .text(t.aiSimulatorWhy, ML, sy + 4, { width: CW, lineGap: 2 });
        sy += doc.heightOfString(t.aiSimulatorWhy, { width: CW, lineGap: 2 }) + 12;
      } else {
        sy += 4;
      }

      // Query display
      if (rd.aiSimulator.query) {
        doc.roundedRect(ML, sy, CW, 30, 4).fill(C.bgAccent);
        doc.font("KrRegular").fontSize(9).fillColor(C.blue)
          .text(`💬 "${rd.aiSimulator.query}"`, ML + 12, sy + 8, { width: CW - 24 });
        sy += 38;
      }

      // Mention rate summary
      doc.roundedRect(ML, sy, CW, 36, 4).fill(C.navy);
      doc.font("KrBold").fontSize(12).fillColor(C.white)
        .text(rd.aiSimulator.mentionRate, ML + 16, sy + 10, { width: CW - 32 });
      sy += 44;

      // AI results table
      const simColW = [120, 70, 60, CW - 250];
      const simRowH = 32;
      // Header
      doc.rect(ML, sy, CW, simRowH).fill(C.navy);
      const simHeaders = ["AI 엔진", "추천 여부", "순위", "맥락 / 사유"];
      simHeaders.forEach((h, i) => {
        let hx = ML + 8;
        for (let j = 0; j < i; j++) hx += simColW[j];
        doc.font("KrBold").fontSize(8.5).fillColor(C.white)
          .text(h, hx, sy + 9, { width: simColW[i] - 16, align: i >= 1 && i <= 2 ? "center" : "left" });
      });
      sy += simRowH;

      rd.aiSimulator.results.forEach((r, idx) => {
        // 동적 행 높이 계산
        const ctxText = stripMarkdown(r.context);
        doc.font("KrRegular").fontSize(8);
        const ctxH = ctxText ? doc.heightOfString(ctxText, { width: simColW[3] - 20, lineGap: 2 }) : 0;
        const rowH = Math.max(simRowH, ctxH + 18);

        sy = ensureSpace(doc, sy, rowH + 2, hCtx);
        const bgColor = idx % 2 === 0 ? C.white : C.bg;
        doc.rect(ML, sy, CW, rowH).fill(bgColor);
        doc.moveTo(ML, sy + rowH).lineTo(ML + CW, sy + rowH).lineWidth(0.3).strokeColor(C.border).stroke();

        let cx = ML + 8;
        // Engine name
        doc.font("KrBold").fontSize(9).fillColor(C.text)
          .text(r.engine, cx, sy + 9, { width: simColW[0] - 16 });
        cx += simColW[0];
        // Mentioned
        const mColor = r.mentioned ? C.pass : C.fail;
        const mLabel = r.mentioned ? t.aiSimRecommended : t.aiSimNotRecommended;
        doc.roundedRect(cx + 4, sy + 6, simColW[1] - 16, 18, 3).fill(r.mentioned ? C.passLight : C.failLight);
        doc.font("KrBold").fontSize(8).fillColor(mColor)
          .text(mLabel, cx + 4, sy + 10, { width: simColW[1] - 16, align: "center" });
        cx += simColW[1];
        // Rank
        doc.font("KrRegular").fontSize(9).fillColor(C.textMid)
          .text(r.rank !== null ? `#${r.rank}` : "-", cx, sy + 9, { width: simColW[2] - 16, align: "center" });
        cx += simColW[2];
        // Context
        doc.font("KrRegular").fontSize(8).fillColor(C.textMid)
          .text(ctxText, cx + 4, sy + 9, { width: simColW[3] - 20, lineGap: 2 });
        sy += rowH;
      });

      // Verdict
      if (rd.aiSimulator.verdict) {
        sy += 8;
        sy = ensureSpace(doc, sy, 40, hCtx);
        sy = drawInfoBox(doc, sy, rd.aiSimulator.verdict, C.navy, hCtx);
      }
    }

    // ═══════════════════════════════════════════════
    // SECTION: 네이버 Cue: 대응 진단
    // ═══════════════════════════════════════════════
    if (rd.naverCueDiagnosis && rd.naverCueDiagnosis.items.length > 0) {
      doc.addPage();
      drawPageHeader(doc, t, audit.url);
      let ny = MT;
      ny = drawSectionTitle(doc, ny, t.naverCueTitle, t.naverCueSub);
      if (t.naverCueWhy) {
        doc.font("KrRegular").fontSize(8.5).fillColor(C.blue)
          .text(t.naverCueWhy, ML, ny + 4, { width: CW, lineGap: 2 });
        ny += doc.heightOfString(t.naverCueWhy, { width: CW, lineGap: 2 }) + 12;
      } else {
        ny += 8;
      }

      // Overall score
      const ncColor = rd.naverCueDiagnosis.score >= 70 ? C.pass : rd.naverCueDiagnosis.score >= 40 ? C.warn : C.fail;
      doc.roundedRect(ML, ny, CW, 40, 4).fill(C.bg);
      doc.roundedRect(ML, ny, CW, 40, 4).lineWidth(0.5).strokeColor(ncColor).stroke();
      doc.font("KrBold").fontSize(22).fillColor(ncColor)
        .text(`${rd.naverCueDiagnosis.score}`, ML + 16, ny + 8, { width: 60 });
      doc.font("KrRegular").fontSize(9).fillColor(C.textMuted)
        .text("/ 100", ML + 55, ny + 18, { width: 40 });
      // Progress bar
      const ncBarW = CW - 180;
      doc.roundedRect(ML + 160, ny + 16, ncBarW, 10, 3).fill(C.grayBar);
      doc.roundedRect(ML + 160, ny + 16, ncBarW * rd.naverCueDiagnosis.score / 100, 10, 3).fill(ncColor);
      ny += 52;

      // Items
      rd.naverCueDiagnosis.items.forEach((item, idx) => {
        const iColor = item.status === "양호" ? C.pass : item.status === "미흡" ? C.warn : C.fail;
        const iBg = item.status === "양호" ? C.greenTint : item.status === "미흡" ? C.warnLight : C.failLight;
        const dText = stripMarkdown(item.detail);
        const rText = item.recommendation ? stripMarkdown(item.recommendation) : "";
        doc.font("KrRegular").fontSize(8.5);
        const dH = dText ? doc.heightOfString(dText, { width: CW - 28, lineGap: 2 }) : 0;
        doc.font("KrRegular").fontSize(8);
        const rH = rText ? doc.heightOfString(`\u2192 ${rText}`, { width: CW - 28, lineGap: 2 }) : 0;
        const cardH = Math.max(50, 28 + dH + rH + 8);

        ny = ensureSpace(doc, ny, cardH + 8, hCtx);
        doc.roundedRect(ML, ny, CW, cardH, 3).fill(iBg);
        doc.roundedRect(ML, ny, CW, cardH, 3).lineWidth(0.5).strokeColor(iColor).stroke();
        // Criterion
        doc.font("KrBold").fontSize(10).fillColor(C.text)
          .text(stripMarkdown(item.criterion), ML + 14, ny + 8, { width: CW - 100 });
        // Status badge
        doc.roundedRect(ML + CW - 62, ny + 6, 50, 18, 3).fill(iColor);
        doc.font("KrBold").fontSize(7.5).fillColor(C.white)
          .text(item.status, ML + CW - 62, ny + 10, { width: 50, align: "center" });
        // Detail
        let iy = ny + 28;
        if (dText) {
          doc.font("KrRegular").fontSize(8.5).fillColor(C.textMid)
            .text(dText, ML + 14, iy, { width: CW - 28, lineGap: 2 });
          iy += dH + 4;
        }
        // Recommendation
        if (rText) {
          doc.font("KrRegular").fontSize(8).fillColor(iColor)
            .text(`\u2192 ${rText}`, ML + 14, iy, { width: CW - 28, lineGap: 2 });
        }
        ny += cardH + 8;
      });

      // Verdict
      if (rd.naverCueDiagnosis.verdict) {
        ny = ensureSpace(doc, ny, 40, hCtx);
        ny = drawInfoBox(doc, ny, rd.naverCueDiagnosis.verdict, ncColor, hCtx);
      }
    }

    // ═══════════════════════════════════════════════
    // SECTION: 전략 가이드 (웹사이트 변환 + 콘텐츠 + 마케팅 + mybiseo)
    // ═══════════════════════════════════════════════
    const hasGuide = rd.websiteTransformGuide || rd.contentStrategy || rd.marketingDirection || rd.mybiseoServices;
    if (hasGuide) {
      doc.addPage();
      drawPageHeader(doc, t, audit.url);
      let sgy = MT;
      sgy = drawSectionTitle(doc, sgy, t.strategicGuideTitle, t.strategicGuideSub);
      sgy += 8;  // 전략 가이드는 서브타이틀에 이미 맥락 포함

      // ── 웹사이트 변환 가이드 ──
      if (rd.websiteTransformGuide) {
        sgy = ensureSpace(doc, sgy, 40, hCtx);
        sgy = drawSubTitle(doc, sgy, t.guideWebsite);
        if (rd.websiteTransformGuide.currentState) {
          sgy = drawInfoBox(doc, sgy, rd.websiteTransformGuide.currentState, C.textMid, hCtx);
          sgy += 4;
        }
        if (rd.websiteTransformGuide.transformations) {
          rd.websiteTransformGuide.transformations.forEach((tr) => {
            const prioColor = tr.priority === "높음" ? C.fail : tr.priority === "중간" ? C.warn : C.pass;
            const trIssueText = stripMarkdown(tr.currentIssue);
            const trRecoText = stripMarkdown(tr.recommendation);
            const trImpactText = stripMarkdown(tr.estimatedImpact);
            const trBodyText = `${trIssueText} \u2192 ${trRecoText}`;
            doc.font("KrRegular").fontSize(8.5);
            const trBodyH2 = doc.heightOfString(trBodyText, { width: CW - 28, lineGap: 2 });
            doc.font("KrRegular").fontSize(8);
            const trImpactH2 = doc.heightOfString(`\u2605 ${trImpactText}`, { width: CW - 28, lineGap: 2 });
            const trCardH = Math.max(44, 24 + trBodyH2 + 4 + trImpactH2 + 8);
            sgy = ensureSpace(doc, sgy, trCardH + 8, hCtx);
            doc.roundedRect(ML, sgy, CW, trCardH, 3).fill(C.bg);
            doc.roundedRect(ML, sgy, CW, trCardH, 3).lineWidth(0.5).strokeColor(C.border).stroke();
            // Area + priority badge
            doc.font("KrBold").fontSize(9.5).fillColor(C.text)
              .text(stripMarkdown(tr.area), ML + 12, sgy + 6, { width: CW - 100 });
            doc.roundedRect(ML + CW - 60, sgy + 4, 48, 14, 3).fill(prioColor);
            doc.font("KrBold").fontSize(7).fillColor(C.white)
              .text(tr.priority, ML + CW - 60, sgy + 7, { width: 48, align: "center" });
            // Recommendation
            doc.font("KrRegular").fontSize(8.5).fillColor(C.textMid)
              .text(trBodyText, ML + 14, sgy + 24, { width: CW - 28, lineGap: 2 });
            const trImpactY = sgy + 24 + trBodyH2 + 4;
            doc.font("KrRegular").fontSize(8).fillColor(C.pass)
              .text(`\u2605 ${trImpactText}`, ML + 14, trImpactY, { width: CW - 28, lineGap: 2 });
            sgy += trCardH + 8;
          });
        }
        sgy += 8;
      }

      // ── 콘텐츠 전략 ──
      if (rd.contentStrategy) {
        sgy = ensureSpace(doc, sgy, 60, hCtx);
        sgy = drawHorizontalLine(doc, sgy);
        sgy = drawSubTitle(doc, sgy, t.guideContent);
        if (rd.contentStrategy.currentAssessment) {
          sgy = drawInfoBox(doc, sgy, rd.contentStrategy.currentAssessment, C.blue, hCtx);
          sgy += 4;
        }
        // Strategies
        const strategies = [
          { label: "블로그 전략", text: rd.contentStrategy.blogStrategy },
          { label: "FAQ 전략", text: rd.contentStrategy.faqStrategy },
          { label: "비교표 전략", text: rd.contentStrategy.comparisonTableStrategy },
        ];
        strategies.forEach((s) => {
          if (s.text) {
            sgy = ensureSpace(doc, sgy, 30, hCtx);
            doc.font("KrBold").fontSize(9).fillColor(C.navy)
              .text(s.label, ML + 8, sgy, { width: 80 });
            const sFullText = stripMarkdown(s.text);
            doc.font("KrRegular").fontSize(9).fillColor(C.textMid)
              .text(sFullText, ML + 90, sgy, { width: CW - 100, lineGap: 2 });
            sgy += doc.heightOfString(sFullText, { width: CW - 100, lineGap: 2 }) + 6;
          }
        });
        // Content calendar
        if (rd.contentStrategy.contentCalendar && rd.contentStrategy.contentCalendar.length > 0) {
          sgy += 4;
          sgy = ensureSpace(doc, sgy, 30, hCtx);
          doc.font("KrBold").fontSize(9).fillColor(C.navy)
            .text("콘텐츠 캘린더", ML + 8, sgy, { width: 100 });
          sgy += 16;
          rd.contentStrategy.contentCalendar.forEach((cal) => {
            sgy = ensureSpace(doc, sgy, 18, hCtx);
            doc.font("KrRegular").fontSize(8.5).fillColor(C.textMid)
              .text(`${cal.week} | ${cal.topic} | ${cal.format} | ${cal.targetKeyword}`, ML + 16, sgy, { width: CW - 32, lineGap: 2 });
            sgy += 14;
          });
        }
        sgy += 8;
      }

      // ── 마케팅 방향 ──
      if (rd.marketingDirection) {
        sgy = ensureSpace(doc, sgy, 60, hCtx);
        sgy = drawHorizontalLine(doc, sgy);
        sgy = drawSubTitle(doc, sgy, t.guideMarketing);
        if (rd.marketingDirection.overallStrategy) {
          sgy = drawInfoBox(doc, sgy, rd.marketingDirection.overallStrategy, C.navy, hCtx);
          sgy += 4;
        }
        if (rd.marketingDirection.channelStrategies) {
          rd.marketingDirection.channelStrategies.forEach((ch) => {
            sgy = ensureSpace(doc, sgy, 30, hCtx);
            const chPrioColor = ch.priority === "높음" ? C.fail : ch.priority === "중간" ? C.warn : C.pass;
            doc.font("KrBold").fontSize(9).fillColor(C.text)
              .text(ch.channel, ML + 8, sgy, { width: 80 });
            doc.roundedRect(ML + 90, sgy - 2, 36, 14, 3).fill(chPrioColor);
            doc.font("KrBold").fontSize(7).fillColor(C.white)
              .text(ch.priority, ML + 90, sgy, { width: 36, align: "center" });
            const chStratText = stripMarkdown(ch.strategy);
            doc.font("KrRegular").fontSize(8.5).fillColor(C.textMid)
              .text(chStratText, ML + 132, sgy, { width: CW - 140, lineGap: 2 });
            sgy += doc.heightOfString(chStratText, { width: CW - 140, lineGap: 2 }) + 6;
          });
        }
        // Coexistence message
        if (rd.marketingDirection.coexistenceMessage) {
          sgy += 4;
          sgy = ensureSpace(doc, sgy, 30, hCtx);
          doc.roundedRect(ML, sgy, CW, 28, 3).fill(C.bgAccent);
          doc.font("KrRegular").fontSize(8.5).fillColor(C.blue)
            .text(`🤝 ${stripMarkdown(rd.marketingDirection.coexistenceMessage)}`, ML + 12, sgy + 7, { width: CW - 24, lineGap: 2 });
          sgy += 34;
        }
        sgy += 8;
      }

      // ── mybiseo 서비스 소개 ──
      if (rd.mybiseoServices) {
        sgy = ensureSpace(doc, sgy, 60, hCtx);
        sgy = drawHorizontalLine(doc, sgy);
        sgy = drawSubTitle(doc, sgy, t.guideMybiseo);
        if (rd.mybiseoServices.headline) {
          doc.font("KrBold").fontSize(11).fillColor(C.navy)
            .text(stripMarkdown(rd.mybiseoServices.headline), ML + 8, sgy, { width: CW - 16, lineGap: 3 });
          sgy += doc.heightOfString(stripMarkdown(rd.mybiseoServices.headline), { width: CW - 16, lineGap: 3 }) + 8;
        }
        if (rd.mybiseoServices.services) {
          rd.mybiseoServices.services.forEach((svc) => {
            const svcFullText = `${stripMarkdown(svc.description)} \u2014 ${stripMarkdown(svc.relevanceToHospital)}`;
            doc.font("KrRegular").fontSize(8.5);
            const svcTextH = doc.heightOfString(svcFullText, { width: CW - 28, lineGap: 2 });
            const svcCardH = Math.max(40, 20 + svcTextH + 10);
            sgy = ensureSpace(doc, sgy, svcCardH + 8, hCtx);
            doc.roundedRect(ML, sgy, CW, svcCardH, 3).fill(C.bgAccent);
            doc.font("KrBold").fontSize(9.5).fillColor(C.blue)
              .text(svc.name, ML + 14, sgy + 6, { width: CW - 28 });
            doc.font("KrRegular").fontSize(8.5).fillColor(C.textMid)
              .text(svcFullText, ML + 14, sgy + 20, { width: CW - 28, lineGap: 2 });
            sgy += svcCardH + 8;
          });
        }
        if (rd.mybiseoServices.ctaMessage) {
          sgy = ensureSpace(doc, sgy, 30, hCtx);
          doc.roundedRect(ML, sgy, CW, 26, 3).fill(C.navy);
          doc.font("KrBold").fontSize(10).fillColor(C.white)
            .text(stripMarkdown(rd.mybiseoServices.ctaMessage), ML + 16, sgy + 6, { width: CW - 32, align: "center" });
          sgy += 32;
        }
      }
    }
  }

  // ═══════════════════════════════════════════════
  // PAGES: CRITICAL ISSUES (즉시 개선 필요)
  // ═══════════════════════════════════════════════
  const failItems = audit.categories.flatMap(c => c.items.filter(i => i.status === "fail"));
  if (failItems.length > 0) {
    // Start on new page for critical issues
    doc.addPage();
    drawPageHeader(doc, t, audit.url);
    let y = MT;

    y = drawSectionTitle(doc, y, t.criticalIssues);
    y = drawParagraph(doc, y, t.criticalDesc, { color: C.textMid, fontSize: 9.5 });
    y += 4;

    failItems.forEach((item, idx) => {
      const itemName = ITEM_NAMES_KO[item.id] || item.name;
      const detailText = stripMarkdown(item.detail || "");
      const recoText = stripMarkdown(item.recommendation || "");
      const impactText = stripMarkdown(item.impact || "");

      // Calculate card height
      doc.font("KrRegular").fontSize(9);
      const detailH = detailText ? doc.heightOfString(detailText, { width: CW - 32, lineGap: 3 }) : 0;
      const recoH = recoText ? doc.heightOfString(recoText, { width: CW - 32, lineGap: 3 }) : 0;
      const impactH = impactText ? doc.heightOfString(impactText, { width: CW - 32, lineGap: 3 }) : 0;

      let cardH = 44; // header
      if (detailText) cardH += detailH + 22;
      if (recoText) cardH += recoH + 22;
      if (impactText) cardH += impactH + 22;
      cardH += 8;

      y = ensureSpace(doc, y, cardH + 8, hCtx);

      // Card
      doc.roundedRect(ML, y, CW, cardH, 4).lineWidth(0.5).strokeColor(C.border).stroke();
      // Top accent bar
      doc.rect(ML, y, CW, 3).fill(C.fail);

      // Header row
      doc.font("KrBold").fontSize(11).fillColor(C.text)
        .text(itemName, ML + 14, y + 12, { width: CW - 100 });

      // Score badge
      doc.font("KrBold").fontSize(9).fillColor(C.fail)
        .text(`${item.score}/${item.maxScore}`, ML + CW - 70, y + 14, { width: 56, align: "right" });

      let iy = y + 40;

      // Current status
      if (detailText) {
        doc.font("KrBold").fontSize(8.5).fillColor(C.textLight)
          .text(t.currentStatus, ML + 14, iy, { width: CW - 28 });
        iy += 14;
        doc.font("KrRegular").fontSize(9).fillColor(C.text)
          .text(detailText, ML + 14, iy, { width: CW - 32, lineGap: 3 });
        iy += detailH + 8;
      }

      // Recommendation
      if (recoText) {
        doc.font("KrBold").fontSize(8.5).fillColor(C.textLight)
          .text(t.recommendation, ML + 14, iy, { width: CW - 28 });
        iy += 14;
        doc.font("KrRegular").fontSize(9).fillColor(C.text)
          .text(recoText, ML + 14, iy, { width: CW - 32, lineGap: 3 });
        iy += recoH + 8;
      }

      // Expected impact
      if (impactText) {
        doc.font("KrBold").fontSize(8.5).fillColor(C.textLight)
          .text(t.expectedImpact, ML + 14, iy, { width: CW - 28 });
        iy += 14;
        doc.font("KrRegular").fontSize(9).fillColor(C.blue)
          .text(impactText, ML + 14, iy, { width: CW - 32, lineGap: 3 });
      }

      y += cardH + 6;
    });
  }

  // ═══════════════════════════════════════════════
  // PAGES: WARNING ISSUES (주의 필요)
  // ═══════════════════════════════════════════════
  const warnItems = audit.categories.flatMap(c => c.items.filter(i => i.status === "warning"));
  if (warnItems.length > 0) {
    // Start on new page for warning issues
    doc.addPage();
    drawPageHeader(doc, t, audit.url);
    let y = MT;

    y = drawSectionTitle(doc, y, t.warningIssues);
    y = drawParagraph(doc, y, t.warningDesc, { color: C.textMid, fontSize: 9.5 });
    y += 4;

    warnItems.forEach((item, idx) => {
      const itemName = ITEM_NAMES_KO[item.id] || item.name;
      const detailText = stripMarkdown(item.detail || "");
      const recoText = stripMarkdown(item.recommendation || "");
      const impactText = stripMarkdown(item.impact || "");

      doc.font("KrRegular").fontSize(9);
      const detailH = detailText ? doc.heightOfString(detailText, { width: CW - 32, lineGap: 3 }) : 0;
      const recoH = recoText ? doc.heightOfString(recoText, { width: CW - 32, lineGap: 3 }) : 0;
      const impactH = impactText ? doc.heightOfString(impactText, { width: CW - 32, lineGap: 3 }) : 0;

      let cardH = 44;
      if (detailText) cardH += detailH + 22;
      if (recoText) cardH += recoH + 22;
      if (impactText) cardH += impactH + 22;
      cardH += 8;

      y = ensureSpace(doc, y, cardH + 8, hCtx);

      doc.roundedRect(ML, y, CW, cardH, 4).lineWidth(0.5).strokeColor(C.border).stroke();
      doc.rect(ML, y, CW, 3).fill(C.warn);

      doc.font("KrBold").fontSize(11).fillColor(C.text)
        .text(itemName, ML + 14, y + 12, { width: CW - 100 });
      doc.font("KrBold").fontSize(9).fillColor(C.warn)
        .text(`${item.score}/${item.maxScore}`, ML + CW - 70, y + 14, { width: 56, align: "right" });

      let iy = y + 40;

      if (detailText) {
        doc.font("KrBold").fontSize(8.5).fillColor(C.textLight)
          .text(t.currentStatus, ML + 14, iy, { width: CW - 28 });
        iy += 14;
        doc.font("KrRegular").fontSize(9).fillColor(C.text)
          .text(detailText, ML + 14, iy, { width: CW - 32, lineGap: 3 });
        iy += detailH + 8;
      }

      if (recoText) {
        doc.font("KrBold").fontSize(8.5).fillColor(C.textLight)
          .text(t.recommendation, ML + 14, iy, { width: CW - 28 });
        iy += 14;
        doc.font("KrRegular").fontSize(9).fillColor(C.text)
          .text(recoText, ML + 14, iy, { width: CW - 32, lineGap: 3 });
        iy += recoH + 8;
      }

      if (impactText) {
        doc.font("KrBold").fontSize(8.5).fillColor(C.textLight)
          .text(t.expectedImpact, ML + 14, iy, { width: CW - 28 });
        iy += 14;
        doc.font("KrRegular").fontSize(9).fillColor(C.blue)
          .text(impactText, ML + 14, iy, { width: CW - 32, lineGap: 3 });
      }

      y += cardH + 6;
    });
  }

  // ═══════════════════════════════════════════════
  // PAGE: ACTION PLAN (단계별 개선 계획)
  // ═══════════════════════════════════════════════
  doc.addPage();
  drawPageHeader(doc, t, audit.url);
  let ay = MT;

  ay = drawSectionTitle(doc, ay, t.actionPlan);
  ay = drawParagraph(doc, ay, t.actionDesc, { color: C.textMid, fontSize: 9.5 });
  ay += 8;

  // Phase cards
  const phases = [
    { title: t.phase1, items: failItems.slice(0, 3), color: C.fail },
    { title: t.phase2, items: warnItems.slice(0, 5), color: C.warn },
    { title: t.phase3, items: [...failItems.slice(3), ...warnItems.slice(5)], color: C.blue },
  ];

  phases.forEach((phase) => {
    if (phase.items.length === 0) return;
    ay = ensureSpace(doc, ay, 60, hCtx);

    // Phase title with accent
    doc.rect(ML, ay, 4, 18).fill(phase.color);
    doc.font("KrBold").fontSize(12).fillColor(C.navy)
      .text(phase.title, ML + 14, ay, { width: CW - 14 });
    ay += 26;

    // Items as compact list
    phase.items.forEach((item) => {
      ay = ensureSpace(doc, ay, 24, hCtx);
      const itemName = ITEM_NAMES_KO[item.id] || item.name;
      // Bullet
      doc.circle(ML + 14, ay + 6, 3).fill(phase.color);
      doc.font("KrRegular").fontSize(9.5).fillColor(C.text)
        .text(itemName, ML + 24, ay, { width: CW - 40 });
      // Brief recommendation
      if (item.recommendation) {
        const brief = stripMarkdown(item.recommendation).substring(0, 80);
        doc.font("KrRegular").fontSize(8).fillColor(C.textLight)
          .text(brief + (item.recommendation.length > 80 ? "..." : ""), ML + 24, ay + 14, { width: CW - 40 });
        ay += 30;
      } else {
        ay += 18;
      }
    });
    ay += 8;
  });

  // ═══════════════════════════════════════════════
  // PAGES: FULL AUDIT TABLE
  // ═══════════════════════════════════════════════
  doc.addPage();
  drawPageHeader(doc, t, audit.url);
  let fy = MT;

  fy = drawSectionTitle(doc, fy, t.fullAudit);
  fy = drawParagraph(doc, fy, t.fullAuditDesc, { color: C.textMid, fontSize: 9.5 });
  fy += 6;

  // Table header
  const auditColW = [170, 55, 55, 200];
  const auditRowH = 26;
  doc.rect(ML, fy, CW, auditRowH).fill(C.navy);
  [t.item, t.status, t.score, t.detail].forEach((label, i) => {
    let hx = ML + 6;
    for (let j = 0; j < i; j++) hx += auditColW[j];
    doc.font("KrBold").fontSize(8.5).fillColor(C.white)
      .text(label, hx, fy + 7, { width: auditColW[i] - 12, align: i >= 1 && i <= 2 ? "center" : "left" });
  });
  fy += auditRowH;

  // All items sorted: fail first, then warning, then pass
  const allItems = audit.categories.flatMap(c => c.items);
  const sortedItems = [...allItems].sort((a, b) => {
    const order = { fail: 0, warning: 1, pass: 2 };
    return (order[a.status] ?? 2) - (order[b.status] ?? 2);
  });

  sortedItems.forEach((item, idx) => {
    const itemName = ITEM_NAMES_KO[item.id] || item.name;
    const detailFull = stripMarkdown(item.detail || "");

    // Calculate row height based on detail text
    doc.font("KrRegular").fontSize(8);
    const detailH = detailFull ? doc.heightOfString(detailFull, { width: auditColW[3] - 16, lineGap: 2 }) : 12;
    const rowH = Math.max(auditRowH, detailH + 12);

    fy = ensureSpace(doc, fy, rowH + 2, hCtx);
    if (fy <= MT + 2) {
      // Re-draw table header on new page (page header already drawn by ensureSpace)
      doc.rect(ML, fy, CW, auditRowH).fill(C.navy);
      [t.item, t.status, t.score, t.detail].forEach((label, i) => {
        let hx = ML + 6;
        for (let j = 0; j < i; j++) hx += auditColW[j];
        doc.font("KrBold").fontSize(8.5).fillColor(C.white)
          .text(label, hx, fy + 7, { width: auditColW[i] - 12, align: i >= 1 && i <= 2 ? "center" : "left" });
      });
      fy += auditRowH;
    }

    const bgColor = idx % 2 === 0 ? C.white : C.bg;
    doc.rect(ML, fy, CW, rowH).fill(bgColor);
    doc.moveTo(ML, fy + rowH).lineTo(PW - MR, fy + rowH).lineWidth(0.3).strokeColor(C.border).stroke();

    let cx = ML + 6;
    // Item name
    doc.font("KrRegular").fontSize(8.5).fillColor(C.text)
      .text(itemName, cx, fy + 7, { width: auditColW[0] - 12 });
    cx += auditColW[0];
    // Status
    const sColor = statusColor(item.status);
    const sBg = statusBg(item.status);
    const sLabel = statusLabel(item.status, t);
    doc.roundedRect(cx + 4, fy + 5, auditColW[1] - 16, 16, 3).fill(sBg);
    doc.font("KrBold").fontSize(7.5).fillColor(sColor)
      .text(sLabel, cx + 4, fy + 8, { width: auditColW[1] - 16, align: "center" });
    cx += auditColW[1];
    // Score
    doc.font("KrRegular").fontSize(8.5).fillColor(C.textMid)
      .text(`${item.score}/${item.maxScore}`, cx, fy + 7, { width: auditColW[2] - 8, align: "center" });
    cx += auditColW[2];
    // Detail
    doc.font("KrRegular").fontSize(8).fillColor(C.textMid)
      .text(detailFull, cx + 4, fy + 7, { width: auditColW[3] - 16, lineGap: 2 });

    fy += rowH;
  });

  // ═══════════════════════════════════════════════
  // PASSED ITEMS — 간략 요약 (통과 항목 수 + 카테고리별 요약)
  // ═══════════════════════════════════════════════
  const passItems = audit.categories.flatMap(c => c.items.filter(i => i.status === "pass"));
  if (passItems.length > 0) {
    // 통과 항목을 별도 페이지 대신 액션 플랜 페이지 하단에 간략 요약으로 표시
    ay = ensureSpace(doc, ay, 80, hCtx);
    ay = drawHorizontalLine(doc, ay);
    ay = drawSubTitle(doc, ay, t.passedItems);

    // 통과 항목 수 요약 박스
    const passBoxH = 40;
    doc.roundedRect(ML, ay, CW, passBoxH, 4).fill(C.passLight);
    doc.roundedRect(ML, ay, CW, passBoxH, 4).lineWidth(0.5).strokeColor(C.pass).stroke();
    doc.font("KrBold").fontSize(13).fillColor(C.pass)
      .text(`✓ ${passItems.length}`, ML + 16, ay + 8, { width: 60 });
    doc.font("KrRegular").fontSize(9.5).fillColor(C.text)
      .text(t.passedDesc, ML + 70, ay + 12, { width: CW - 86, lineGap: 2 });
    ay += passBoxH + 8;

    // 카테고리별 통과 항목 수 (2줄 컴팩트)
    const passByCat = new Map<string, string[]>();
    passItems.forEach(item => {
      const cat = audit.categories.find(c => c.items.some(ci => ci.id === item.id));
      const catName = cat ? (CAT_NAMES_KO[cat.name] || cat.name) : "기타";
      if (!passByCat.has(catName)) passByCat.set(catName, []);
      passByCat.get(catName)!.push(ITEM_NAMES_KO[item.id] || item.name);
    });
    const catSummaries = Array.from(passByCat.entries()).map(([cat, items]) => `${cat}(${items.length})`);
    doc.font("KrRegular").fontSize(8.5).fillColor(C.textMid)
      .text(catSummaries.join(" | "), ML + 8, ay, { width: CW - 16, lineGap: 2 });
    ay += doc.heightOfString(catSummaries.join(" | "), { width: CW - 16, lineGap: 2 }) + 8;
  }

  // ═══════════════════════════════════════════════
  // PAGE: HISTORY TREND (부록 위치)
  // ═══════════════════════════════════════════════
  try {
    // Monthly Score Trend
    const domain = audit.url.replace(/^https?:\/\//, "").replace(/\/+$/, "");
    const trendData = await getMonthlyTrendByUrl(domain);
    const comparison = await getScoreComparisonByUrl(domain);

    if (comparison && comparison.first && comparison.latest) {
      doc.addPage();
      drawPageHeader(doc, t, audit.url);
      let y = MT;

      y = drawSectionTitle(doc, y, t.historyTitle, t.historySub);
      y += 4;
      y = drawParagraph(doc, y, t.historyDesc, { color: C.textMid });
      y += 8;

      // Score comparison cards
      const compW = (CW - 30) / 3;
      const compH = 80;

      // First diagnosis card
      let cx = ML;
      doc.roundedRect(cx, y, compW, compH, 4).fill(C.bg);
      doc.roundedRect(cx, y, compW, compH, 4).lineWidth(0.5).strokeColor(C.border).stroke();
      doc.font("KrRegular").fontSize(8.5).fillColor(C.textLight)
        .text(t.historyFirst, cx + 12, y + 10, { width: compW - 24 });
      doc.font("KrBold").fontSize(28).fillColor(C.navy)
        .text(`${comparison.first.score}`, cx + 12, y + 28, { width: compW - 24 });
      doc.font("KrRegular").fontSize(8).fillColor(C.textMuted)
        .text(comparison.first.date || "", cx + 12, y + 60, { width: compW - 24 });

      // Latest diagnosis card
      cx += compW + 15;
      doc.roundedRect(cx, y, compW, compH, 4).fill(C.bg);
      doc.roundedRect(cx, y, compW, compH, 4).lineWidth(0.5).strokeColor(C.border).stroke();
      doc.font("KrRegular").fontSize(8.5).fillColor(C.textLight)
        .text(t.historyLatest, cx + 12, y + 10, { width: compW - 24 });
      doc.font("KrBold").fontSize(28).fillColor(C.navy)
        .text(`${comparison.latest.score}`, cx + 12, y + 28, { width: compW - 24 });
      doc.font("KrRegular").fontSize(8).fillColor(C.textMuted)
        .text(comparison.latest.date || "", cx + 12, y + 60, { width: compW - 24 });

      // Change card
      cx += compW + 15;
      const diff = comparison.latest.score - comparison.first.score;
      const changeColor = diff > 0 ? C.pass : diff < 0 ? C.fail : C.textMid;
      const changeText = diff > 0 ? `+${diff}` : `${diff}`;
      doc.roundedRect(cx, y, compW, compH, 4).fill(diff > 0 ? C.passLight : diff < 0 ? C.failLight : C.bg);
      doc.roundedRect(cx, y, compW, compH, 4).lineWidth(0.5).strokeColor(C.border).stroke();
      doc.font("KrRegular").fontSize(8.5).fillColor(C.textLight)
        .text(t.historyChange, cx + 12, y + 10, { width: compW - 24 });
      doc.font("KrBold").fontSize(28).fillColor(changeColor)
        .text(changeText, cx + 12, y + 28, { width: compW - 24 });
      const changeDesc = diff > 0 ? t.historyImproved : diff < 0 ? t.historyDeclined : t.historyNoChange;
      doc.font("KrRegular").fontSize(8).fillColor(C.textMid)
        .text(changeDesc, cx + 12, y + 60, { width: compW - 24 });

      y += compH + 20;

      // Monthly trend table (if data exists)
      if (trendData && trendData.length > 1) {
        y = drawSubTitle(doc, y, t.historyScore);

        // Simple bar chart using table
        const maxScore = Math.max(...trendData.map((d: any) => d.score || 0), 100);
        const barAreaW = CW - 100;

        trendData.slice(-12).forEach((d: any, idx: number) => {
          y = ensureSpace(doc, y, 24, hCtx);
          const label = d.month || d.date || `#${idx + 1}`;
          doc.font("KrRegular").fontSize(8.5).fillColor(C.textMid)
            .text(label, ML, y + 2, { width: 80 });

          const barW = (d.score / maxScore) * barAreaW;
          const barColor = d.score >= 70 ? C.pass : d.score >= 40 ? C.warn : C.fail;
          doc.rect(ML + 85, y, barAreaW, 16).fill(C.bg);
          doc.rect(ML + 85, y, Math.max(barW, 2), 16).fill(barColor);
          doc.font("KrBold").fontSize(8).fillColor(C.white)
            .text(`${d.score}`, ML + 85 + Math.max(barW - 30, 4), y + 3, { width: 28, align: "right" });

          y += 22;
        });

        y += 10;
      }

      // Summary stats
      if (comparison.totalDiagnoses > 1) {
        y = ensureSpace(doc, y, 40, hCtx);
        const days = comparison.periodDays || 0;
        const statsText = `${t.historyPeriod}: ${days}${t.historyDays}  |  ${t.historyDiagnoses}: ${comparison.totalDiagnoses}${t.historyTimes}`;
        doc.font("KrRegular").fontSize(9).fillColor(C.textLight)
          .text(statsText, ML, y, { width: CW, align: "center" });
      }
    }
  } catch (e) {
    // History trend page error (skipping)
    console.error("History trend page error (skipping):", e);
  }

  // ═══════════════════════════════════════════════
  // PAGE: FINAL ASSESSMENT (closingStatement 재활용 — LLM 호출 제거로 성능 개선)
  // ═══════════════════════════════════════════════
  if (rd?.closingStatement) {
    doc.addPage();
    drawPageHeader(doc, t, audit.url);
    let fy2 = MT;

    fy2 = drawSectionTitle(doc, fy2, t.finalAssessment, t.finalAssessmentSub);
    fy2 += 8;

    const assessmentText = stripMarkdown(rd.closingStatement);
    if (assessmentText) {
      const paragraphs = assessmentText.split(/\n\n+/).filter((p: string) => p.trim());
      paragraphs.forEach((para: string) => {
        const trimmed = para.trim();
        if (!trimmed) return;

        doc.font("KrRegular").fontSize(10);
        const pH = doc.heightOfString(trimmed, { width: CW, lineGap: 5 });

        if (fy2 + pH + 8 > MAX_Y) {
          doc.addPage();
          drawPageHeader(doc, t, audit.url);
          fy2 = MT;
        }

        doc.font("KrRegular").fontSize(10).fillColor(C.text)
          .text(trimmed, ML, fy2, { width: CW, lineGap: 5 });
        fy2 += pH + 10;
      });
    }
  }

  // ═══════════════════════════════════════════════
  // CONTACT INFORMATION PAGE
  // PAGE: CONTACT (전문가 상담 안내)
  // ═══════════════════════════════════════════════
  doc.addPage();
  drawPageHeader(doc, t, audit.url);

  const ctaY = 260;

  // Title
  doc.font("KrBold").fontSize(20).fillColor(C.navy)
    .text(t.ctaTitle, ML, ctaY, { width: CW, align: "center" });

  // Description
  doc.font("KrRegular").fontSize(10.5).fillColor(C.textMid)
    .text(t.ctaDesc1, ML, ctaY + 36, { width: CW, align: "center", lineGap: 4 });
  doc.font("KrRegular").fontSize(10.5).fillColor(C.textMid)
    .text(t.ctaDesc2, ML, ctaY + 54, { width: CW, align: "center", lineGap: 4 });

  // Contact info
  doc.font("KrRegular").fontSize(10).fillColor(C.text)
    .text(t.ctaPhone, ML, ctaY + 90, { width: CW, align: "center" });
  doc.font("KrRegular").fontSize(10).fillColor(C.text)
    .text(t.ctaWeb, ML, ctaY + 108, { width: CW, align: "center" });

  // QR Code (캐시 활용)
  try {
    if (!cachedQrBuffer) {
      const qrDataUrl = await QRCode.toDataURL("https://mybiseo.com", {
        width: 80,
        margin: 1,
        color: { dark: C.navy, light: "#FFFFFF" },
      });
      cachedQrBuffer = Buffer.from(qrDataUrl.split(",")[1], "base64");
    }
    doc.image(cachedQrBuffer, PW / 2 - 40, ctaY + 130, { width: 80, height: 80 });
  } catch (e) {
    // QR generation failed
  }

  // Disclaimer
  doc.font("KrRegular").fontSize(7.5).fillColor(C.textMuted)
    .text(t.disclaimer, ML, PH - 100, { width: CW, align: "center", lineGap: 3, height: 60 });

  // ═══════════════════════════════════════════════
  // PAGE NUMBERS (applied to all pages)
  // ═══════════════════════════════════════════════
  const range = doc.bufferedPageRange();
  const totalPages = range.count;
  for (let i = 0; i < totalPages; i++) {
    doc.switchToPage(i);
    if (i === 0) continue; // Skip cover page
    // CRITICAL: height option prevents PDFKit from auto-creating new pages when writing near page bottom
    doc.font("KrRegular").fontSize(8).fillColor(C.textMuted)
      .text(`${i} / ${totalPages - 1}`, ML, PH - 36, { width: CW, align: "center", lineBreak: false, height: 12 });
  }

  // Finalize
  return new Promise<Buffer>((resolve, reject) => {
    doc.on("end", () => resolve(Buffer.concat(chunks)));
    doc.on("error", reject);
    doc.end();
  });
}
